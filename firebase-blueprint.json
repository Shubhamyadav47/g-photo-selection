{
  "entities": {
    "user": {
      "title": "User Profile",
      "description": "Stores private metadata and credit balances/stats for photographer accounts.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "credits": { "type": "integer", "description": "Active gallery credits balance for compiling and downloading interactive selection galleries" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "credits", "createdAt", "updatedAt"]
    },
    "gallery": {
      "title": "Gallery Metadata",
      "description": "Metadata for a compiled/downloaded gallery generated by the photographer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "imagesCount": { "type": "integer" },
        "whatsappNumber": { "type": "string" },
        "hasPassword": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "imagesCount", "hasPassword", "createdAt"]
    },
    "transaction": {
      "title": "Transaction Receipt",
      "description": "History of credit purchases styled with INR details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "integer" },
        "creditsAdded": { "type": "integer" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "amount", "creditsAdded", "status", "paymentMethod", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "Photographer profile and credits record."
    },
    "/users/{userId}/galleries/{galleryId}": {
      "schema": "gallery",
      "description": "Galleries compiled and downloaded by the user."
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "transaction",
      "description": "INR purchase history ledger."
    }
  }
}
